{
    "_description": "DSE parameter space for GPU architecture exploration",
    "_version": "1.0",

    "baseline": "configs/GA100.json",

    "parameters": {
        "core_count": {
            "values": [32, 48, 64, 96, 128, 192, 256],
            "description": "Number of active SMs",
            "baseline": 128
        },
        "hbm_channel_count": {
            "values": [3, 4, 5, 6, 8],
            "description": "Number of active HBM memory channels (each 128-bit)",
            "baseline": 5
        },
        "global_buffer_MB": {
            "values": [20, 40, 60, 80, 120],
            "description": "L2 cache size in MB",
            "baseline": 48
        },
        "systolic_array_dim": {
            "values": [8, 16, 32],
            "description": "Systolic array height=width dimension",
            "baseline": 16
        },
        "sram_KB": {
            "values": [64, 128, 192, 256, 512],
            "description": "Per-core L1 SRAM in KB",
            "baseline": 192
        }
    },

    "fixed_parameters": {
        "device_counts": [1, 4, 8],
        "clock_freq_Hz": 1410000000,
        "memory_protocol": "HBM2e"
    },

    "workloads": [
        {
            "name": "llama_7b_prefill",
            "d_model": 4096,
            "n_heads": 32,
            "n_layers": 32,
            "batch_size": 16,
            "seq_len": 1024,
            "phase": "prefill",
            "device_count": 1
        },
        {
            "name": "llama_7b_decode",
            "d_model": 4096,
            "n_heads": 32,
            "n_layers": 32,
            "batch_size": 1,
            "seq_len": 1024,
            "phase": "decode",
            "device_count": 1
        },
        {
            "name": "llama_70b_prefill",
            "d_model": 8192,
            "n_heads": 64,
            "n_layers": 80,
            "batch_size": 16,
            "seq_len": 1024,
            "phase": "prefill",
            "device_count": 4
        },
        {
            "name": "llama_70b_decode",
            "d_model": 8192,
            "n_heads": 64,
            "n_layers": 80,
            "batch_size": 1,
            "seq_len": 512,
            "phase": "decode",
            "device_count": 4
        }
    ],

    "constraints": {
        "max_die_area_mm2": 900,
        "description": "Reticle limit for die area"
    },

    "objectives": [
        "prefill_latency",
        "decode_latency",
        "die_area_mm2"
    ]
}
